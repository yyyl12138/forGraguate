# Shared backend runtime environment template for stages 9.5-12.
# Use this file on node1 to avoid rewriting the same JDBC/Fabric settings in each stage.
# Keep backend/src/main/resources/application.yml local-friendly until the final hardening step.

# Load example on node1:
#   cp ./backend-runtime.env.example ./backend-runtime.env
#   set -a
#   source ./backend-runtime.env
#   set +a

# MySQL: quote JDBC URLs because they contain '&'
LOGTRACE_NODE1_JDBC_URL='jdbc:mysql://127.0.0.1:3306/logtrace_node1?useUnicode=true&characterEncoding=utf8&connectionTimeZone=UTC'
LOGTRACE_NODE1_JDBC_USERNAME=logtrace_app
LOGTRACE_NODE1_JDBC_PASSWORD=CHANGE_ME_NODE1

LOGTRACE_NODE2_JDBC_URL='jdbc:mysql://192.168.88.102:3306/logtrace_node2?useUnicode=true&characterEncoding=utf8&connectionTimeZone=UTC'
LOGTRACE_NODE2_JDBC_USERNAME=logtrace_app
LOGTRACE_NODE2_JDBC_PASSWORD=CHANGE_ME_NODE2

LOGTRACE_NODE3_JDBC_URL='jdbc:mysql://192.168.88.103:3306/logtrace_node3?useUnicode=true&characterEncoding=utf8&connectionTimeZone=UTC'
LOGTRACE_NODE3_JDBC_USERNAME=logtrace_app
LOGTRACE_NODE3_JDBC_PASSWORD=CHANGE_ME_NODE3

# Fabric Gateway
LOGTRACE_LEDGER_MODE=fabric
LOGTRACE_LEDGER_CHANNEL_NAME=mychannel
LOGTRACE_LEDGER_CHAINCODE_NAME=log-evidence
LOGTRACE_LEDGER_MSP_ID=Org1MSP
LOGTRACE_LEDGER_PEER_ENDPOINT=peer0.org1.example.com:7051
LOGTRACE_LEDGER_OVERRIDE_AUTHORITY=peer0.org1.example.com
LOGTRACE_LEDGER_TLS_CERT_PATH=/home/yangli/Documents/fabric-workspace/gateway/org1/peer0.org1.example.com/tls/ca.crt
LOGTRACE_LEDGER_CLIENT_CERT_PATH=/home/yangli/Documents/fabric-workspace/gateway/org1/users/Admin@org1.example.com/msp/signcerts/Admin@org1.example.com-cert.pem
LOGTRACE_LEDGER_CLIENT_KEY_DIR=/home/yangli/Documents/fabric-workspace/gateway/org1/users/Admin@org1.example.com/msp/keystore

# Security
LOGTRACE_JWT_SECRET=CHANGE_ME_WITH_AT_LEAST_32_BYTES
LOGTRACE_ACCESS_TOKEN_TTL_SECONDS=3600
LOGTRACE_REFRESH_TOKEN_TTL_SECONDS=604800

# Stage 10 internal ingest + auto seal
LOGTRACE_INTERNAL_INGEST_SHARED_TOKEN=CHANGE_ME_STAGE10_MACHINE_TOKEN
LOGTRACE_AUTO_SEAL_ENABLED=false
LOGTRACE_AUTO_SEAL_SOURCE=tomcat-cve-2017-12615
LOGTRACE_AUTO_SEAL_POLL_INTERVAL_MILLIS=15000
LOGTRACE_AUTO_SEAL_BUFFER_SECONDS=90
LOGTRACE_AUTO_SEAL_MAX_WINDOWS_PER_RUN=10
LOGTRACE_AUTO_SEAL_EARLIEST_WINDOW_START=

# Optional stage-specific flags can be appended below in later stages.
