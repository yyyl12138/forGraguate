[Unit]
Description=LogTrace Stage10 Filebeat Relay
After=network.target

[Service]
Type=simple
User=yangli
WorkingDirectory=/home/yangli/Documents/logtrace/ops/stage10
EnvironmentFile=/home/yangli/Documents/logtrace/ops/stage10/relay.env
ExecStart=/usr/bin/python3 /home/yangli/Documents/logtrace/ops/stage10/log-relay.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
